{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "_comment": "Console is deliberately quiet so the ReviewProgressReporter's stage lines stand out (picked -> setup -> reviewing -> done). This filter is CONSOLE-ONLY; the opt-in JSONL sink (CodeReviewDaemon:LogFilePath) keeps full Debug detail for DuckDB. SingleLine collapses each entry to one readable line.",
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "HH:mm:ss "
      },
      "LogLevel": {
        "Default": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "CodeReviewDaemon.Sample.Workspace.ReviewSlotPreparer": "Error",
        "CodeReviewDaemon.Sample.Workspace.Git.SubmoduleInitializer": "Error",
        "CodeReviewDaemon.Sample.Diagnostics.CopilotModelCatalogLogger": "Information",
        "CodeReviewDaemon.Sample.Orchestration.ReviewProgressReporter": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Webhook": {
      "PublicBaseUrl": "http://127.0.0.1:5080"
    }
  },
  "CodeReviewDaemon": {
    "EnableCommentPosting": false,
    "EnableKnowledgeAgent": false,
    "EnableJudgeAgent": false,
    "EnableABVariants": false,
    "EnableAdoProvider": false,
    "EnabledRepos": []
  }
}
