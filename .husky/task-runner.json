{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "format-verify",
         "group": "pre-commit",
         "command": "dotnet",
         "args": [
            "format",
            "whitespace",
            "LmDotnetTools.sln",
            "--verify-no-changes",
            "--verbosity",
            "quiet"
         ]
      }
   ]
}
